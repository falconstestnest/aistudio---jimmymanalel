# GEMINI_API_KEY: Required for Gemini AI API calls (local Express / AI Studio).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public site URL (optional for self-links).
APP_URL="https://www.jimmymanalel.com"

# ---------------------------------------------------------------------------
# HubSpot — Forms-based website lead capture (server-side only)
# Set these on Vercel Project → Settings → Environment Variables.
# Never use VITE_ for private tokens / form GUIDs / portal IDs used for writes.
# ---------------------------------------------------------------------------

# Public HubSpot portal / account ID (numeric). Forms submission API.
HUBSPOT_PORTAL_ID=""

# Form GUIDs from HubSpot → Marketing → Forms (one per lead type)
HUBSPOT_FORM_ID_ADVISORY=""
HUBSPOT_FORM_ID_BOOKING=""
HUBSPOT_FORM_ID_ASSESSMENT=""
HUBSPOT_FORM_ID_PARTNERSHIP=""

# Preview only: allow dry-run responses when form config is incomplete.
# Must NOT be true in production (production always fails closed with 503).
HUBSPOT_ALLOW_DRY_RUN="false"

# Legacy Contacts sandbox (/api/hubspot/*). Disabled for anonymous production traffic.
# Set a strong secret and send header: x-jm-sandbox-key: <secret>
HUBSPOT_SANDBOX_SECRET=""
HUBSPOT_ACCESS_TOKEN=""

# ---------------------------------------------------------------------------
# HubSpot tracking (analytics only — independent of form submissions)
# Disabled until consent is granted AND tracking is explicitly enabled.
# ---------------------------------------------------------------------------
# Public tracking portal id (safe to expose). Example: 246391835
VITE_HUBSPOT_TRACKING_CODE_ID=""
# Must be "true" only after cookie banner / consent manager is live.
VITE_HUBSPOT_TRACKING_ENABLED="false"
